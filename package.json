{
  "name": "cattle-herd-manager",
  "version": "0.9.1",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -p 9999",
    "build": "next build",
    "start": "next start -p 9999",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:start": "npm run build && NODE_ENV=production electron .",
    "electron:make": "npm run build && electron-forge make",
    "electron:make:macos": "npm run build && electron-forge make --platform darwin",
    "electron:make:windows": "npm run build && electron-forge make --platform win32",
    "lint": "eslint",
    "pm2:start": "pm2 start \"npm run dev\" --name cattle-herd && pm2 save",
    "pm2:stop": "pm2 stop cattle-herd",
    "pm2:restart": "pm2 restart cattle-herd",
    "pm2:logs": "pm2 logs cattle-herd",
    "pm2:status": "pm2 status"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.5.1",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "date-fns": "^4.2.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
    "reactflow": "^11.11.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "electron": "^26.2.2",
    "@electron-forge/cli": "^7.5.0",
    "@electron-forge/maker-dmg": "^7.5.0",
    "@electron-forge/maker-squirrel": "^7.5.0",
    "@electron-forge/maker-zip": "^7.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/csv-parse": "^1.1.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-pdf": "^6.2.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "Cattle Herd Manager",
        "icon": "./public/cattle-icon",
        "asar": true,
        "prune": true
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "CattleHerdManager",
            "exe": "Cattle Herd Manager.exe"
          }
        },
        {
          "name": "@electron-forge/maker-dmg",
          "config": {
            "name": "Cattle Herd Manager"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": ["darwin", "linux"]
        }
      ]
    }
  }
}
