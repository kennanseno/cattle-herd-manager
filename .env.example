# ─── Google Sheets storage (production / Vercel) ─────────────────────────────
# When these are set, the app stores tabular data in Google Sheets. When they
# are absent, it falls back to local CSV files under data/ (useful for local
# development). Photo uploads are only supported by the local backend.
#
# HOW TO GET THESE VALUES (full guide: docs/google-sheets-setup.md):
#   Use a personal @gmail.com account — work/school accounts often block
#   service-account keys.
#   1. Create a project at https://console.cloud.google.com/ (project dropdown
#      → New Project).
#   2. Enable the Google Sheets API:
#      https://console.cloud.google.com/apis/library/sheets.googleapis.com
#   3. Create a Service Account (IAM & Admin → Service Accounts). Its email is
#      GOOGLE_SERVICE_ACCOUNT_EMAIL.
#   4. On that service account: Keys → Add Key → Create new key → JSON. Open the
#      downloaded file; its "private_key" field is GOOGLE_PRIVATE_KEY.
#   5. Create a sheet at https://sheets.new — the ID between /d/ and /edit in
#      the URL is GOOGLE_SHEETS_SPREADSHEET_ID. Share the sheet with the service
#      account email as Editor (required).

# Service account email, e.g. cattle-app@my-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Service account private key. Keep the surrounding quotes and the literal \n
# escapes on a single line, e.g.:
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=

# The spreadsheet ID from its URL:
# https://docs.google.com/spreadsheets/d/<THIS_IS_THE_ID>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# ─── Password gate (optional) ────────────────────────────────────────────────
# When set, the whole app is locked behind a password screen. Visitors must
# enter this exact value before they can access any page or API. Leave it unset
# (e.g. for local development) to disable the gate entirely.
#
# After 5 failed attempts a client is locked out for 5 minutes. This throttle is
# in-memory per server process (best-effort on serverless), so choose a long,
# random value (20+ chars) as the real defense against brute-force guessing.
APP_PASSWORD=
